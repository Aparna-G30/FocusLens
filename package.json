{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "lib": [
      "DOM",
      "ES2022"
    ],
    "types": [
      "chrome"
    ],
    "outDir": "dist"
  },
  "include": [
    "src/**/*"
  ]
}