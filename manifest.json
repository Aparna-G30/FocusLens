{
  "manifest_version": 3,
  "name": "FocusLens",
  "version": "1.0.0",
  "description": "A magical reading companion that highlights the paragraph you're reading, helping you stay focused on any webpage.",

  "permissions": ["storage"],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],

"icons": {
  "16": "assets/icon16.png",
  "32": "assets/icon32.png",
  "48": "assets/icon48.png",
  "128": "assets/icon128.png"
},
"action": {
  "default_popup": "popup.html",
  "default_icon": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
}